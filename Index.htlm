<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Test 3D</title>
    <script src="https://aframe.io/releases/1.5.0/aframe.min.js"></script>
  </head>
  <body>
    <a-scene>
      <a-sky color="#000000"></a-sky>
      
      <a-entity light="type: ambient; intensity: 0.8; color: #ffffff"></a-entity>
      <a-entity light="type: directional; intensity: 0.6" position="2 4 3"></a-entity>
      
      <a-entity geometry="primitive: plane; width: 100; height: 100" rotation="-90 0 0" material="color: #ffffff; wireframe: true;"></a-entity>
      
      <a-box id="entita-autonoma" position="0 1 -3" material="color: #ff0000"></a-box>

      <a-entity camera look-controls position="0 1.6 0"></a-entity>
    </a-scene>
  </body>
</html>
